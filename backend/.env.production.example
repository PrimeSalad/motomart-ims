# Production Environment Variables for Render
# Copy these to your Render dashboard environment variables

NODE_ENV=production
PORT=8080

# Supabase (REQUIRED)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# JWT (REQUIRED - Use a strong random secret)
JWT_SECRET=GENERATE_A_STRONG_RANDOM_SECRET_HERE
JWT_EXPIRES_IN=7d

# CORS (REQUIRED - Your Vercel frontend URL)
CORS_ORIGIN=https://your-app.vercel.app

# App URL (REQUIRED - Your Vercel frontend URL)
APP_PUBLIC_URL=https://your-app.vercel.app

# Security
BCRYPT_SALT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# System Owner (REQUIRED - Your admin email)
SYSTEM_OWNER_EMAILS=your-email@example.com

# Optional: Gemini AI
GEMINI_API_KEY=

# Optional: SMTP for password reset emails
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="IMS <no-reply@ims.local>"
