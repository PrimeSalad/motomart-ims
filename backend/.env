# -----------------------------
# Carbon & Crimson IMS - Backend
# File: .env.example
# Version: 1.1.0
# Purpose: Environment template for backend.
# -----------------------------

NODE_ENV=development
PORT=8080


# =============================
# MongoDB
# =============================

MONGO_URI=mongodb://localhost:27017/ims_db


# =============================
# JWT Security
# =============================

JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET
JWT_EXPIRES_IN=7d


# =============================
# Frontend URL (CORS + Reset Links)
# =============================

CORS_ORIGIN=http://localhost:5173

# Used for password reset links
APP_PUBLIC_URL=http://localhost:5173


# =============================
# Motorcycle APIs
# =============================

# Primary Motorcycle API

BCRYPT_SALT_ROUNDS=10
# Secondary AI Compatibility API (Gemini)
GEMINI_API_KEY=AIzaSyAy3nmZgk-7_IWIi9F-5qmvMm9XqAoGMk4

# =============================
# Default Users (Auto Seed)
# =============================

SEED_ADMIN_EMAIL=admin@ims.local
SEED_ADMIN_PASSWORD=Admin#1234

SEED_STAFF_EMAIL=staff@ims.local
SEED_STAFF_PASSWORD=Staff#1234


# =============================
# Email Settings (Password Reset)
# =============================

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
GEMINI_MODEL= 
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

MAIL_FROM="MotoMart IMS <your_email@gmail.com>"


# =============================
# Rate Limiting (Security)
# =============================

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120